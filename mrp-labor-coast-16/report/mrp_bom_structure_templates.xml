<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_bom_structure_labor_cost"
              inherit_id="mrp.report_bom_structure">
        <!--
            "Birim Maliyeti" satırını içeren tr'nin öncesine
            İşçilik Maliyeti satırını ekliyoruz.
        -->
        <xpath expr="//tr[hasclass('o_bom_report_line_unit_price')]"
               position="before">
            <t t-if="data.get('labor_cost_value')">
                <tr class="o_bom_report_line_labor_cost">
                    <td colspan="5">
                        <strong>İşçilik Maliyeti</strong>
                    </td>
                    <td class="text-right">
                        <t t-esc="data.get('labor_cost_currency').symbol or ''"/>
                        <t t-esc="'%.2f' % (data.get('labor_cost_value') or 0)"/>
                    </td>
                </tr>
            </t>
        </xpath>
    </template>

</odoo>
