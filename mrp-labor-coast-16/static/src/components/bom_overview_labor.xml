<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="mrp.BomOverview" t-inherit-mode="extension">
        <xpath expr="//tfoot" position="before">
            <t t-if="state.bomData and state.bomData.labor_cost_value">
                <tbody>
                    <tr class="table-warning">
                        <td colspan="5" class="fw-bold">
                            <i class="fa fa-wrench me-1"/>
                            İşçilik Maliyeti
                        </td>
                        <td class="text-end fw-bold" colspan="2">
                            <t t-esc="state.bomData.labor_cost_value.toFixed(2)"/>
                        </td>
                        <td colspan="2"/>
                    </tr>
                </tbody>
            </t>
        </xpath>
    </t>

</templates>
